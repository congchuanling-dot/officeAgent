<UserControl x:Class="agentOffice.UI.TaskPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:agentOffice.UI"
             Width="340" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="#2B579A" Padding="12,10">
            <Grid>
                <TextBlock Text="🤖 Word AI 助手" Foreground="White" FontSize="15" FontWeight="Bold"/>
                <Button Content="⚙" HorizontalAlignment="Right" Width="28" Height="28"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        FontSize="14" Cursor="Hand" Click="Settings_Click"/>
            </Grid>
        </Border>

        <!-- 消息列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Messages}" Margin="6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" Margin="0,3" CornerRadius="6" Background="#F8F8F8">
                            <StackPanel>
                                <TextBlock Text="{Binding Role}" FontWeight="Bold" FontSize="12" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13" LineHeight="18"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 设置面板 -->
        <Border Grid.Row="1" Background="White" Padding="14"
                Visibility="{Binding ShowSettings, Converter={x:Static local:TaskPaneControl.BoolToVis}}">
            <StackPanel>
                <TextBlock Text="⚙ 设置" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                <TextBlock Text="DeepSeek API Key" FontSize="12" Foreground="#666"/>
                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,8" Padding="6" FontSize="12"/>
                <Button Content="💾 保存" Width="80" Height="30" Background="#2B579A"
                        Foreground="White" BorderThickness="0" Cursor="Hand" Click="SaveSettings_Click"/>
                <TextBlock Margin="0,8,0,0">
                    <Hyperlink Click="GetKey_Click" Foreground="#2B579A">如何获取 Key？</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 输入框 -->
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="8,6">
            <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" MinHeight="32" MaxHeight="60"
                     TextWrapping="Wrap" FontSize="13" BorderThickness="0" Background="Transparent"
                     IsEnabled="{Binding IsBusy, Converter={x:Static local:TaskPaneControl.InvBool}}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding SendCmd}"/>
                </TextBox.InputBindings>
            </TextBox>
        </Border>

        <!-- 底部按钮栏 -->
        <Border Grid.Row="3" Padding="8,4,8,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="📤 发送" Width="70" Height="30" Background="#2B579A"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Command="{Binding SendCmd}" IsEnabled="{Binding CanSend}"/>
                <TextBlock Text="{Binding Status}" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="✅ 确认" Width="70" Height="30" Background="#388E3C"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Command="{Binding ConfirmCmd}" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
