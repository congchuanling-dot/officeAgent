<!--
  ============================================================
  🎨 任务面板视图 — WPF XAML 布局

  结构（4 行 Grid）：
    Row 0: 标题栏（蓝色底 + "Word AI 助手" + ⚙设置按钮）
    Row 1: 主区域（消息列表 ScrollViewer / 设置面板，互斥显示）
    Row 2: 输入框（多行 TextBox，Ctrl+Enter 发送）
    Row 3: 底部按钮栏（发送 + 状态文字 + 确认）

  绑定关系：
    ItemsControl     ← Messages（ObservableCollection<ChatMessage>）
    TextBox          ← Input（双向）
    TextBox.IsEnabled← IsBusy（取反）
    设置面板 Visibility← ShowSettings（BoolToVis）
    发送按钮 IsEnabled← CanSend
    状态文字          ← Status
-->
<UserControl x:Class="agentOffice.UI.TaskPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:agentOffice.UI"
             Width="340" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
            <RowDefinition Height="*"/>     <!-- 消息区域 + 设置面板（填满剩余空间） -->
            <RowDefinition Height="Auto"/>  <!-- 输入框 -->
            <RowDefinition Height="Auto"/>  <!-- 底部按钮栏 -->
        </Grid.RowDefinitions>

        <!-- ===== Row 0: 标题栏 ===== -->
        <Border Grid.Row="0" Background="#2B579A" Padding="12,10">
            <Grid>
                <TextBlock Text="🤖 Word AI 助手" Foreground="White"
                           FontSize="15" FontWeight="Bold"/>
                <!-- ⚙ 设置按钮，点击切换设置面板显隐 -->
                <Button Content="⚙" HorizontalAlignment="Right" Width="28" Height="28"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        FontSize="14" Cursor="Hand" Click="Settings_Click"/>
            </Grid>
        </Border>

        <!-- ===== Row 1: 消息列表（与设置面板互斥显示） ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Messages}" Margin="6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 每条消息：圆角气泡卡片 -->
                        <Border Padding="8,6" Margin="0,3" CornerRadius="6"
                                Background="#F8F8F8">
                            <StackPanel>
                                <!-- 角色标识：👤用户 / 🤖AI / ✅成功 / ❌错误 -->
                                <TextBlock Text="{Binding Role}" FontWeight="Bold"
                                           FontSize="12" Margin="0,0,0,3"/>
                                <!-- 消息正文，自动换行 -->
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                           FontSize="13" LineHeight="18"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===== Row 1: 设置面板（ShowSettings=true 时覆盖消息区域） ===== -->
        <Border Grid.Row="1" Background="White" Padding="14"
                Visibility="{Binding ShowSettings,
                             Converter={x:Static local:TaskPaneControl.BoolToVis}}">
            <StackPanel>
                <TextBlock Text="⚙ 设置" FontSize="15" FontWeight="Bold"
                           Margin="0,0,0,12"/>
                <TextBlock Text="DeepSeek API Key" FontSize="12" Foreground="#666"/>
                <!-- ApiKey 双向绑定，实时同步到 VM -->
                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,8" Padding="6" FontSize="12"/>
                <Button Content="💾 保存" Width="80" Height="30" Background="#2B579A"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="SaveSettings_Click"/>
                <TextBlock Margin="0,8,0,0">
                    <Hyperlink Click="GetKey_Click" Foreground="#2B579A">
                        如何获取 Key？
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ===== Row 2: 输入框 ===== -->
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0"
                Padding="8,6">
            <!-- 多行输入，Ctrl+Enter 发送，IsBusy 时禁用 -->
            <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" MinHeight="32" MaxHeight="60"
                     TextWrapping="Wrap" FontSize="13" BorderThickness="0"
                     Background="Transparent"
                     IsEnabled="{Binding IsBusy,
                                 Converter={x:Static local:TaskPaneControl.InvBool}}">
                <TextBox.InputBindings>
                    <!-- Ctrl+Enter → SendCmd -->
                    <KeyBinding Key="Enter" Modifiers="Control"
                                Command="{Binding SendCmd}"/>
                </TextBox.InputBindings>
            </TextBox>
        </Border>

        <!-- ===== Row 3: 底部按钮栏 ===== -->
        <Border Grid.Row="3" Padding="8,4,8,8">
            <StackPanel Orientation="Horizontal">
                <!-- 📤 发送按钮，绑定 CanSend 控制是否可用 -->
                <Button Content="📤 发送" Width="70" Height="30"
                        Background="#2B579A" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding SendCmd}"
                        IsEnabled="{Binding CanSend}"/>

                <!-- 状态文字：就绪 / 分析中... / 请确认 / 执行中... -->
                <TextBlock Text="{Binding Status}" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                <!-- ✅ 确认按钮，执行 AI 返回的命令 -->
                <Button Content="✅ 确认" Width="70" Height="30"
                        Background="#388E3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ConfirmCmd}" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
