{
    // ====== C# 语言服务器 (C# Dev Kit) ======
    "dotnet.defaultSolution": "agentoffice/agentOffice.sln",

    // ====== 排除 bin/obj，加快索引 ======
    "files.exclude": {
        "**/bin": true,
        "**/obj": true,
        "**/.vs": true
    },
    "files.watcherExclude": {
        "**/bin/**": true,
        "**/obj/**": true
    }
}
